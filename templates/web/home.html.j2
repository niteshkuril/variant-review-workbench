{% extends "web/base.html.j2" %}

{% block content %}
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Analyst Interface</p>
        <div class="chip-row">
          <span class="chip">ClinVar-first</span>
          <span class="chip">Research use only</span>
          <span class="chip">Shared backend pipeline</span>
        </div>
        <h1>Review a VCF through the same pipeline used by the CLI.</h1>
        <p class="hero-lead">
          The browser workflow reuses the existing ClinVar-first annotation, ranking, reporting, and export
          stack. It is designed for review and reproducible artifact generation, not for clinical operations.
        </p>
        <p>
          Hosted runs write into isolated workspaces and the service reuses a shared processed ClinVar cache.
          The retention window of {{ web_scope.run_retention_hours }} hour{% if web_scope.run_retention_hours != 1 %}s{% endif %}
          applies to run workspaces, not to cache warm-up per query.
        </p>
        <div class="actions">
          <a class="button" href="#run-setup">Start a run</a>
          <a class="button ghost" href="{{ url_for('docs') }}">Review workflow details</a>
        </div>
      </div>
      <div class="meta-card">
        <strong>Hosted web profile</strong>
        <p>The site accepts a VCF upload, runs the shared pipeline, renders the generated HTML report, and exposes HTML, JSON, or Markdown exports from the completed run.</p>
        <dl class="data-list">
          <div>
            <dt>Input cap</dt>
            <dd>{{ web_scope.max_upload_mb }} MB</dd>
          </div>
          <div>
            <dt>Assemblies</dt>
            <dd>GRCh37 / GRCh38</dd>
          </div>
          <div>
            <dt>Retention window</dt>
            <dd>{{ web_scope.run_retention_hours }}h run cleanup</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="panel" style="margin-top: 24px;">
    <div class="fact-grid">
      <div class="fact-card">
        <strong>Input</strong>
        <span class="metric">VCF</span>
        <p>Accepts validated `.vcf` and `.vcf.gz` uploads up to {{ web_scope.max_upload_mb }} MB per submission.</p>
      </div>
      <div class="fact-card">
        <strong>Execution</strong>
        <span class="metric">Shared</span>
        <p>The web layer calls the same backend service, reporting code, and export generation paths as the CLI.</p>
      </div>
      <div class="fact-card">
        <strong>Outputs</strong>
        <span class="metric">3 Formats</span>
        <p>Open the report in-browser or download the resulting HTML, JSON, or Markdown artifact after completion.</p>
      </div>
    </div>
  </section>

  <section class="panel" id="run-setup" style="margin-top: 24px;">
    <h2>Run Setup</h2>
    <p class="muted">Submit a VCF, confirm the coordinate system, and choose whether the run should open in the browser or redirect straight to an export artifact.</p>
    <div class="subtle-divider"></div>
    <form class="stack" method="post" action="{{ url_for('create_run') }}" enctype="multipart/form-data" data-run-form>
      {% if form_error %}
        <div class="notice error">
          <strong>Submission error</strong>
          <p>{{ form_error }}</p>
        </div>
      {% endif %}
      <div class="grid-two">
        <div class="field">
          <label for="vcf_file">VCF upload</label>
          <input id="vcf_file" name="vcf_file" type="file" accept=".vcf,.vcf.gz,.gz" required>
          <small>Use a local `.vcf` or `.vcf.gz` file. Uploaded inputs are isolated per run.</small>
        </div>

        <div class="field">
          <label for="assembly">Assembly</label>
          <select id="assembly" name="assembly">
            <option value="GRCh38">GRCh38</option>
            <option value="GRCh37">GRCh37</option>
          </select>
          <small>Pick the assembly that matches the uploaded VCF coordinates.</small>
        </div>
      </div>

      <fieldset class="fieldset">
        <legend>Options</legend>
        <div class="checklist">
          <label class="check" for="enable_pharmgkb">
            <input id="enable_pharmgkb" name="enable_pharmgkb" type="checkbox" value="true">
            <span>Enable PharmGKB enrichment</span>
          </label>
          <label class="check" for="mode_export_only">
            <input id="mode_export_only" name="mode" type="checkbox" value="export_only" data-export-only>
            <span>Skip browser report and go straight to export</span>
          </label>
        </div>
      </fieldset>

      <div class="field" data-export-format-field>
        <label for="export_format">Preferred export format</label>
        <select id="export_format" name="export_format">
          <option value="json">JSON</option>
          <option value="html">HTML</option>
          <option value="md">Markdown</option>
        </select>
        <small>Only used when "skip browser report" is selected.</small>
      </div>

      <div class="notice">
        <strong>Hosted process</strong>
        <p>The shared ClinVar cache is prepared ahead of time and reused across hosted runs. Individual uploads do not trigger a full cache build.</p>
        <p>Run workspaces are temporary and may remain on disk until cleanup occurs. Do not submit protected health information or production patient data.</p>
      </div>

      <div class="actions">
        <button type="submit" data-submit-button data-loading="false">
          <span class="loading-label-default">Run in browser</span>
          <span class="loading-label-active">Submitting run...</span>
        </button>
        <a class="button secondary" href="{{ url_for('docs') }}">Open overview</a>
      </div>
      <p class="footer-note">This interface is scoped to research triage, reproducible outputs, and transparent artifact provenance.</p>
    </form>
  </section>
{% endblock %}
