{% extends "web/base.html.j2" %}

{% block content %}
  <section class="hero" data-run-root data-run-id="{{ run_id }}" data-run-status="{{ job.status }}">
    <div class="status-grid">
      <div>
        <p class="eyebrow">Run Results</p>
        <h1>Review the generated report and exported artifacts.</h1>
        <p>
          This page embeds the actual report artifact produced by the shared backend pipeline. The browser interface
          is reading the same generated outputs that the CLI writes to disk.
        </p>
        <div class="actions">
          {% if job.result and job.status == "succeeded" %}
            <a class="button" href="{{ url_for('run_export', run_id=run_id, export_format='html') }}">Export HTML</a>
            <a class="button secondary" href="{{ url_for('run_export', run_id=run_id, export_format='json') }}">Export JSON</a>
            <a class="button secondary" href="{{ url_for('run_export', run_id=run_id, export_format='md') }}">Export Markdown</a>
          {% else %}
            <a class="button ghost" href="{{ url_for('home') }}">Start another run</a>
          {% endif %}
        </div>
      </div>
      <div class="meta-card">
        <strong>Run overview</strong>
        <div class="mono">{{ run_id }}</div>
        <div class="subtle-divider"></div>
        <div class="actions-inline">
          <span class="status-badge {{ job.status }}" data-status-badge>{{ job.status }}</span>
        </div>
        <p data-status-message class="muted" style="margin-bottom: 0;">
          {% if job.status == "succeeded" %}
            The report and export artifacts are ready.
          {% elif job.status == "failed" %}
            The job failed before the report could be rendered.
          {% elif job.status == "running" %}
            The job is running now. This page will refresh when the report is ready.
          {% else %}
            The job is queued. This page is polling the status endpoint.
          {% endif %}
        </p>
        <p class="footer-note" style="margin-top: 18px;">
          Non-clinical output only. Run-local files are subject to the configured cleanup window of
          {{ web_scope.run_retention_hours }} hour{% if web_scope.run_retention_hours != 1 %}s{% endif %}.
        </p>
      </div>
    </div>
  </section>

  <section class="panel" style="margin-top: 24px;">
    <div class="panel-header">
      <h2>Job status</h2>
      <span class="mono">{{ url_for('run_status', run_id=run_id) }}</span>
    </div>
    <p class="muted">Use the status endpoint for programmatic polling. The browser refreshes automatically while the job is queued or running.</p>
    <div class="subtle-divider"></div>
    <div class="status-list">
      <div class="status-item">
        <span>Mode</span>
        <strong class="mono">{{ job.mode }}</strong>
      </div>
      <div class="status-item">
        <span>Requested export</span>
        <strong class="mono">{{ job.export_format or "None" }}</strong>
      </div>
      <div class="status-item">
        <span>Current status</span>
        <strong>{{ job.status }}</strong>
      </div>
      {% if job.result %}
        <div class="status-item">
          <span>Uploaded VCF</span>
          <strong class="mono">{{ job.result.uploaded_vcf_path }}</strong>
        </div>
        <div class="status-item">
          <span>Run output directory</span>
          <strong class="mono">{{ job.result.output_dir }}</strong>
        </div>
        <div class="status-item">
          <span>Summary artifact</span>
          <strong class="mono">{{ job.result.summary_json_path }}</strong>
        </div>
        <div class="status-item">
          <span>Report JSON export</span>
          <strong class="mono">{{ job.result.report_json_path }}</strong>
        </div>
        <div class="status-item">
          <span>Report Markdown export</span>
          <strong class="mono">{{ job.result.report_markdown_path }}</strong>
        </div>
      {% elif job.error %}
        <div class="status-item">
          <span>Error</span>
          <strong class="mono">{{ job.error }}</strong>
        </div>
      {% endif %}
    </div>
  </section>

  {% if job.result and job.status == "succeeded" %}
    <section class="panel" style="margin-top: 24px;">
      <div class="fact-grid">
        <div class="fact-card">
          <strong>Input Variants</strong>
          <span class="metric">{{ job.result.summary.input_variant_count }}</span>
          <p>Total uploaded VCF records processed by this run.</p>
        </div>
        <div class="fact-card">
          <strong>ClinVar Matches</strong>
          <span class="metric">{{ job.result.summary.clinvar_matched_count }}</span>
          <p>Exact assembly-aware matches found in the configured ClinVar snapshot.</p>
        </div>
        <div class="fact-card">
          <strong>Conflicts</strong>
          <span class="metric">{{ job.result.summary.conflict_flagged_count }}</span>
          <p>Findings surfaced into the conflict review queue for manual inspection.</p>
        </div>
      </div>
      {% if job.result.summary.input_variant_count > 0 and job.result.summary.clinvar_matched_count == 0 %}
        <div class="notice warning" style="margin-top: 16px;">
          <strong>No ClinVar matches were found for this run.</strong>
          <p>
            All variants were assigned <code>context_only</code>. Confirm the selected assembly
            (<code>{{ job.result.assembly }}</code>) matches the VCF coordinates (for example, GRCh37 versus GRCh38),
            and verify the configured ClinVar snapshot covers these loci. Custom assemblies can only be run via
            command line, requiring a cold start.
          </p>
        </div>
      {% endif %}
    </section>

    <section class="panel" style="margin-top: 24px; padding: 16px;">
      <div class="panel-header" style="padding: 12px 12px 0;">
        <h2>Report Preview</h2>
        <a class="button ghost" href="{{ url_for('run_report', run_id=run_id) }}" target="_blank" rel="noopener noreferrer">Open HTML Report</a>
      </div>
      <div class="notice" style="margin: 12px;">
        <strong>Preview is not auto-loaded.</strong>
        <p>
          The generated HTML report may be large for bigger VCF uploads. Use <em>Open HTML Report</em> to view it on demand.
        </p>
      </div>
    </section>
  {% else %}
    <section class="panel" style="margin-top: 24px;">
      <h2>Current state</h2>
      {% if job.error %}
        <div class="notice error">
          <strong>Run failed</strong>
          <p>{{ job.error }}</p>
        </div>
      {% else %}
        <div class="notice">
          <strong>Waiting on completion</strong>
          <p>The report preview will appear here automatically once the job reaches the `succeeded` state.</p>
        </div>
      {% endif %}
      <ul>
        <li>Generated report will be embedded here when ready.</li>
        <li>Export controls will remain visible after the job succeeds.</li>
        <li>Artifacts and provenance remain bound to the run workspace.</li>
      </ul>
      <p class="footer-note">Do not upload protected health information or rely on this page as a clinical system of record.</p>
    </section>
  {% endif %}
{% endblock %}
