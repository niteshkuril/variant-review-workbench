{% extends "web/base.html.j2" %}

{% block content %}
  <section class="hero">
    <h1>Results Shell</h1>
    <p>
      This page reuses the generated report artifact from the shared backend pipeline. The browser view is not a
      second report implementation.
    </p>
    <div class="meta-card">
      <strong>Run identifier</strong>
      <div class="mono">{{ run_id }}</div>
      <p>Status: <span class="mono">{{ job.status }}</span></p>
      <p>Mode: <span class="mono">{{ job.mode }}</span></p>
      {% if job.export_format %}
        <p>Requested export preference: <span class="mono">{{ job.export_format }}</span></p>
      {% endif %}
    </div>
  </section>

  <section class="panel" style="margin-top: 24px; padding: 28px;">
    <h2>Job status</h2>
    <p>
      Pollable status endpoint:
      <span class="mono">{{ url_for('run_status', run_id=run_id) }}</span>
    </p>
    {% if job.result %}
      <p>{{ job.result.message }}</p>
      <p>Uploaded VCF: <span class="mono">{{ job.result.uploaded_vcf_path }}</span></p>
      <p>Run output directory: <span class="mono">{{ job.result.output_dir }}</span></p>
      <p>Summary artifact: <span class="mono">{{ job.result.summary_json_path }}</span></p>
    {% elif job.error %}
      <p>Job failed: <span class="mono">{{ job.error }}</span></p>
    {% else %}
      <p>The job has been accepted and is waiting for completion.</p>
    {% endif %}
  </section>

  {% if job.result and job.status == "succeeded" %}
    <section class="panel" style="margin-top: 24px; padding: 16px;">
      <h2 style="padding: 12px 12px 0;">Report Preview</h2>
      <iframe
        title="Variant Review Report"
        src="{{ url_for('run_report', run_id=run_id) }}"
        style="width: 100%; min-height: 960px; border: 0; border-radius: 16px; background: white;"
      ></iframe>
    </section>
  {% else %}
    <section class="panel" style="margin-top: 24px; padding: 28px;">
      <h2>Planned result experience</h2>
      <ul>
        <li>Rendered analyst-facing report from the shared reporting pipeline</li>
        <li>Visible provenance and research-use disclaimer</li>
        <li>Export control for JSON, HTML, and Markdown artifacts</li>
      </ul>
    </section>
  {% endif %}
{% endblock %}
